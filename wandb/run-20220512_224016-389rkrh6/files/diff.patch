+   "source": [
+    "def accuracy(model,X,y):\n",
+    "    correct = 0\n",
+    "    total = 0\n",
+    "    preds = model(X)\n",
+    "    for pred,y_batch in zip(preds,y):\n",
+    "        pred = int(torch.argmax(pred))\n",
+    "        y_batch = int(torch.argmax(y_batch))\n",
+    "        if pred == y_batch:\n",
+    "            correct += 1\n",
+    "        total += 1\n",
+    "    acc = round(correct/total,3)*100\n",
+    "    return acc"
+   ]
